# Solar Trust Gate — environment variables
# Copy to .env and fill in your own values. Never commit .env.

# ── Primary: Upstage Solar Pro 3 ───────────────────────────────────
# Required for all Solar judgment (F), L1/L2 verification, and Document AI.
UPSTAGE_API_KEY=
UPSTAGE_MODEL=solar-pro3-260323

# ── Login gate ─────────────────────────────────────────────────────
# Comma-separated shared keys. Empty = auth disabled (open mode).
# Generate keys with: openssl rand -base64 24
AUTH_KEYS=

# ── Port ───────────────────────────────────────────────────────────
# PORT=8090

# ── Optional: Upstage Document AI endpoint overrides ───────────────
# UPSTAGE_DOCAI_BASE=https://api.upstage.ai/document-ai/v1
# UPSTAGE_IE_ENDPOINT=https://api.upstage.ai/v1/information-extraction

# ── Optional: Audit gate provider override ─────────────────────────
# GEM2_GATE_PROVIDER=solar   # default when UPSTAGE_API_KEY is set

# ── Optional: Other LLM providers (legacy / testing only) ──────────
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# VULTR_INFERENCE_API_KEY=
# GEM2_API_KEY=              # GEM² TPMN-Checker SaaS (not needed for Solar flow)

# ── Legacy defaults (overridden by Solar when UPSTAGE_API_KEY set) ──
# GEM2_DEFAULT_LLM=gemini-2.5-flash
# GEM2_DEFAULT_AGENT_LLM=gemini-2.5-flash

# ── Project working directory ───────────────────────────────────────
# PROJECT_DIR=
